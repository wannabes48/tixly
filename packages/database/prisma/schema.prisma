datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Match {
  id          String   @id @default(cuid())
  slug        String   @unique
  matchNumber Int
  round       String
  group       String?
  homeTeamId  String
  awayTeamId  String
  stadiumId   String
  kickoffUtc  DateTime
  status      String   @default("SCHEDULED")
  
  homeTeam    Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  stadium     Stadium  @relation(fields: [stadiumId], references: [id])
  listings    TicketListing[]
}

model Team {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  countryCode   String
  flagUrl       String?
  confederation String
  
  homeMatches   Match[]  @relation("HomeTeam")
  awayMatches   Match[]  @relation("AwayTeam")
}

model Stadium {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  city        String
  countryCode String
  capacity    Int
  lat         Float?
  lng         Float?
  
  matches     Match[]
}

model TicketListing {
  id             String   @id @default(cuid())
  matchId        String
  sellerId       String?
  category       String   // CAT1, CAT2, CAT3, CAT4, ACCESSIBILITY
  section        String?
  row            String?
  quantity       Int
  pricePerTicket Float    // Stored as USD float
  deliveryMethod String   
  status         String   @default("ACTIVE") // ACTIVE, SOLD, CANCELLED
  
  match          Match    @relation(fields: [matchId], references: [id])
  seller         User?    @relation(fields: [sellerId], references: [id])
  orders         Order[]
  holds          TicketHold[]

  @@index([matchId])
  @@index([matchId, status])
}

model TicketHold {
  id        String   @id @default(cuid())
  listingId String
  sessionId String
  quantity  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  listing   TicketListing @relation(fields: [listingId], references: [id])

  @@index([sessionId])
  @@index([listingId])
}

model Order {
  id                    String   @id @default(cuid())
  reference             String   @unique // TIX-2026-XXXXXXXX
  listingId             String
  buyerEmail            String
  buyerName             String
  buyerPhone            String
  quantity              Int
  subtotal              Float
  serviceFee            Float
  total                 Float
  currency              String   @default("USD")
  stripePaymentIntentId String?  @unique
  refundProtection      Boolean  @default(false)
  status                String   @default("PENDING") // PENDING, PAID, CANCELLED, REFUNDED
  ticketHolders         Json     // Array of { firstName, lastName }
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  listing               TicketListing @relation(fields: [listingId], references: [id])
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime?
  image           String?
  role            String    @default("BUYER") // SELLER, ADMIN, BUYER
  stripeConnectId String?   @unique
  kycStatus       String    @default("UNVERIFIED") // UNVERIFIED, PENDING, VERIFIED
  
  accounts        Account[]
  sessions        Session[]
  listings        TicketListing[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
